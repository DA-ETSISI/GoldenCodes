<!DOCTYPE html>
<html lang="es">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      Haz tu voto - Códigos de Oro
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Roboto:wght@300;400;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/app.css" />

    <style>
      body {
        padding-top: 36px;
      }
      
      .category-card {
        transition: transform 0.2s;
        cursor: pointer;
        border-left: 5px solid #ffc107;
      }
      
      .category-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0,0,0,.1);
      }
      
      .vote-item {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 10px;
        border: 1px solid #dee2e6;
      }
    </style>
  </head>

  <body>
    <!-- NAVEGACIÓN -->
    <nav class="navbar navbar-expand-lg fixed-top py-3">
      <div class="container">
        <a class="navbar-brand fs-4" href="/">
          <i class="fa-solid fa-trophy me-2"></i>Códigos de Oro
            </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto align-items-center">
            <li class="nav-item ms-lg-3 mt-2 mt-lg-0">
              <a class="btn btn-voto px-4 py-2" href="/">
                <i class="fa-solid fa-arrow-left me-2"></i>Volver a la Gala
                        </a>
            </li>
            @if(user)
              <li class="nav-item dropdown ms-lg-3">
                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                  <i class="fa-solid fa-user me-1"></i>{{ user.nombre }}
                            </a>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li>
                    <h6 class="dropdown-header">
                      {{ user.email }}
                    </h6>
                  </li>
                  <li>
                    <hr class="dropdown-divider" />
                  </li>
                  <li>
                    <form action="/logout" method="POST">
                      {{ csrfField() }}
                                        <button type="submit" class="dropdown-item">
                        <i class="fa-solid fa-right-from-bracket me-2"></i>Cerrar Sesión
                                        </button>
                    </form>
                  </li>
                </ul>
              </li>
            @endif
          </ul>
        </div>
      </div>
    </nav>

    <section id="votacion" class="py-5 mt-5" style="min-height: calc(100vh - 72px);">
      <div class="container">
        <h2 class="text-center display-4 mb-5">
          <i class="fa-solid fa-ranking-star me-2"></i>Panel de Votación
        </h2>

        <!-- Mensajes Flash -->
        @if(flashMessages.has('error'))
          <div class="alert alert-danger alert-dismissible fade show">
            {{ flashMessages.get('error') }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        @endif
        @if(flashMessages.has('success'))
          <div class="alert alert-success alert-dismissible fade show">
            {{ flashMessages.get('success') }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        @endif
        
        <div class="row">
          <!-- Columna Izquierda: Perfil y Votos Realizados -->
          <div class="col-lg-4 mb-4">
            <div class="card shadow-sm mb-4 border-0">
              <div class="card-header bg-dark text-white">
                <h5 class="mb-0">
                  <i class="fa-solid fa-user-circle me-2"></i>Tu Perfil
                </h5>
              </div>
              <div class="card-body">
                <p>
                  <strong>Nombre:</strong>{{ user.nombre }}
                </p>
                <p>
                  <strong>Email:</strong>{{ user.email }}
                </p>

                @if(user.rol)
                  <p>
                    <strong>Perfil:</strong>                    <span class="badge bg-warning text-dark fs-6">{{ user.rol }}</span>
                  </p>
                  @if(user.curso)
                    <p>
                      <strong>Curso:</strong>                      <span>{{ user.curso == '1' ? '1º' : user.curso == '2' ? '2º' : user.curso == '3/4' ? '3º/4º' : user.curso }}</span>
                    </p>
                  @endif
                  @if(user.grado)
                    <p>
                      <strong>Grado/Especialidad:</strong>                      <span>{{ user.grado }}</span>
                    </p>
                  @endif
                  <hr />
                  <h6>
                    Tus votos registrados (<span id="vote-count-badge">{{ userVotes.length }}</span>):
                  </h6>
                  @if(userVotes.length >= 0)
                    <ul class="list-group list-group-flush small" id="votes-summary-list">
                      @each(v in userVotes)
                        <li class="list-group-item px-0">
                          <strong>{{ v.categoria }}:</strong>                          <br />
                          <span class="text-muted">                            <i class="fa-solid fa-check text-success"></i>
                            @if(v.participante)
                              {{ v.participante.nombreCompleto }}
                            @else
                              ID: {{ v.participanteId }}
                            @endif
                          </span>
                        </li>
                      @endeach
                    </ul>
                  @else
                    <p class="text-muted small">
                      Aún no has votado en ninguna categoría.
                    </p>
                  @endif
                @else
                  <div class="alert alert-warning py-2 small">
                    Debes configurar tu perfil antes de votar. Completa los datos en el formulario principal.
                  </div>
                @endif
              </div>
            </div>

            @if(user.rol)
              <div class="alert alert-info small">
                <strong>Recuerda:</strong>
                Según las bases, puedes votar hasta 3 veces en categorías docentes, 1 vez en Innovación Educativa y 5 veces en PTGAS/PDI por PTGAS según corresponda tu perfil. No puedes votar a la misma persona dos veces en una categoría.
              </div>
            @endif
          </div>

          <!-- Columna Derecha: Formulario de Votación -->
          <div class="col-lg-8">
            @if(!user.rol || (user.rol === 'Estudiante' && !user.curso))
              <!-- Configurar Perfil Inicial -->
              <div class="card shadow border-0" id="setup-profile">
                <div class="card-header bg-warning">
                  <h5 class="mb-0 text-dark">
                    <i class="fa-solid fa-gear me-2"></i>Configuración Inicial
                  </h5>
                </div>
                <div class="card-body p-4">
                  <p>
                    {{ user.rol === 'Estudiante' ? 'Hola, necesitamos que selecciones tu curso antes de comenzar a votar.' : 'Antes de comenzar, dinos a qué colectivo perteneces para mostrarte las categorías correspondientes.' }}
                  </p>
                  <form id="rol-form">
                    <div class="mb-3" style="{{ user.rol ? 'display:none;' : '' }}">
                      <label class="form-label">Perfil / Colectivo</label>
                      <select id="user-rol" class="form-select" required>
                        <option value="" disabled {{ !user.rol ? 'selected' : '' }}>
                          Selecciona una opción
                        </option>
                        <option value="PDI" {{ user.rol === 'PDI' ? 'selected' : '' }}>
                          Personal Docente e Investigador (PDI)
                        </option>
                        <option value="PTGAS" {{ user.rol === 'PTGAS' ? 'selected' : '' }}>
                          Personal Técnico, de Gestión y Administración (PTGAS)
                        </option>
                        <option value="Estudiante" {{ user.rol === 'Estudiante' ? 'selected' : '' }}>
                          Estudiante
                        </option>
                      </select>
                    </div>

                    <!-- Campos adicionales para Estudiante -->
                    <div id="estudiante-fields" style="{{ user.rol === 'Estudiante' ? 'display:block;' : 'display:none;' }}">
                      <div class="mb-3">
                        <label class="form-label">Curso</label>
                        <select id="user-curso" class="form-select">
                          <option value="" disabled selected>Selecciona tu curso</option>
                          <option value="1">1º Curso (Grados)</option>
                          <option value="2">2º Curso (Grados)</option>
                          <option value="3/4">3º/4º Curso (Grados)</option>
                          <option value="CDIA">CDIA</option>
                          <option value="Master">Máster</option>
                        </select>
                      </div>

                      <div class="mb-3" id="grado-container" style="display:none;">
                        <label class="form-label">Grado / Especialidad (3º/4º)</label>
                        <select id="user-grado" class="form-select">
                          <option value="" disabled selected>Selecciona tu grado</option>
                          <option value="Software">Ingeniería del Software</option>
                          <option value="Computadores">Ingeniería de Computadores</option>
                          <option value="TSI">Tecnologías de la Soc. de la Información</option>
                          <option value="Sistemas">Sistemas de Información</option>
                        </select>
                      </div>
                    </div>
                    <button type="button" class="btn btn-dark w-100" id="btn-save-rol">
                      Aplicar y Empezar a Votar
                                    </button>
                  </form>
                </div>
              </div>

              <!-- Contenedor general de votación que se mostrará para nuevos usuarios tras elegir su rol -->
              <div class="card shadow border-0" id="main-voting-area" style="display:none;">
                <form
                  action="/votacion"
                  method="POST"
                  id="main-form-setup"
                  class="p-4 rounded border-top border-5 border-warning ajax-vote-form"
                >
                  {{ csrfField() }}
                  <!-- Campos ocultos para enviar rol si se acaba de configurar -->
                  <input type="hidden" name="rol" id="hidden-rol" />
                  <input type="hidden" name="curso" id="hidden-curso" />
                  <input type="hidden" name="grado" id="hidden-grado" />

                  <h4 class="mb-3">
                    Selecciona tu voto
                  </h4>

                  <div class="mb-4">
                    <label class="form-label fw-bold">Categoría Principal</label>
                    <select id="main-cat-select" class="form-select select-lg" required>
                      <option value="" disabled selected>
                        Elige un grupo de premios
                      </option>
                    </select>
                  </div>

                  <div class="mb-4" id="subcat-container" style="display:none;">
                    <label class="form-label fw-bold text-warning">Curso / Variante</label>
                    <select name="categoria" id="categoria-select" class="form-select" required disabled>
                      <option value="" disabled selected>
                        Primero elige un grupo
                      </option>
                      <!-- Opciones dinámicas en JS -->
                    </select>
                    <div id="cat-help" class="form-text text-muted mt-2">
                    </div>
                  </div>

                  <div class="mb-4">
                    <label class="form-label fw-bold">Candidato / Docente</label>
                    <select name="profesor" id="profesor-select" class="form-select" required disabled>
                      <option value="" disabled selected>
                        Primero elige una variante
                      </option>
                    </select>
                  </div>

                  <button
                    type="submit"
                    class="btn btn-voto w-100 py-3 text-uppercase fw-bold shadow-sm btn-submit-vote"
                  >
                    <i class="fa-solid fa-paper-plane me-2"></i>Emitir Voto
                                </button>
                </form>
              </div>

            @else
              <!-- Formulario de Votación directo para usuarios ya configurados -->
              <div class="card shadow border-0" id="main-voting-area-direct">
                <form
                  action="/votacion"
                  method="POST"
                  id="main-form-direct"
                  class="p-4 rounded border-top border-5 border-warning ajax-vote-form"
                >
                  {{ csrfField() }}
                  <h4 class="mb-3">
                    Emite un nuevo voto
                  </h4>

                  <div class="mb-4">
                    <label class="form-label fw-bold">Categoría Principal</label>
                    <select id="main-cat-select" class="form-select select-lg" required>
                      <option value="" disabled selected>
                        Elige un grupo de premios
                      </option>
                    </select>
                  </div>

                  <div class="mb-4" id="subcat-container" style="display:none;">
                    <label class="form-label fw-bold text-warning">Curso / Variante</label>
                    <select name="categoria" id="categoria-select" class="form-select" required disabled>
                      <option value="" disabled selected>
                        Primero elige un grupo
                      </option>
                    </select>
                    <div id="cat-help" class="form-text text-muted mt-2">
                    </div>
                  </div>

                  <div class="mb-4">
                    <label class="form-label fw-bold">Candidato / Docente</label>
                    <select name="profesor" id="profesor-select" class="form-select" required disabled>
                      <option value="" disabled selected>
                        Primero elige una variante
                      </option>
                    </select>
                  </div>

                  <button
                    type="submit"
                    class="btn btn-voto w-100 py-3 text-uppercase fw-bold shadow-sm btn-submit-vote"
                  >
                    <i class="fa-solid fa-paper-plane me-2"></i>Emitir Voto
                                </button>
                </form>
              </div>
            @endif
          </div>
        </div>
      </div>
    </section>

    <!-- Modal JS Data -->
    <script>
      const userRol = "{{ user.rol || '' }}";
      const userCurso = "{{ user.curso || '' }}";
      const userGrado = "{{ user.grado || '' }}";

      const allProfesores = {{{ JSON.stringify(profesores) }}};

      let votesByCategory = {{{ JSON.stringify(votesByCategory) }}};
      let userVotesList = {{{ JSON.stringify(userVotesJson) }}};
      // Define Hierarchy

      const groupsData = {
        "Mérito Docente": [ {
          name: "Primer curso (Grados)",
          roles: [ "Estudiante" ],
          max: 3,
          filter: "Primer curso (Grados)"
        }, {
          name: "Segundo curso (Grados)",
          roles: [ "Estudiante" ],
          max: 3,
          filter: "Segundo curso (Grados)"
        }, {
          name: "Tercer y cuarto curso (Software)",
          roles: [ "Estudiante" ],
          max: 3,
          filter: "Software"
        }, {
          name: "Tercer y cuarto curso (Computadores)",
          roles: [ "Estudiante" ],
          max: 3,
          filter: "Computadores"
        }, {
          name: "Tercer y cuarto curso (TSI)",
          roles: [ "Estudiante" ],
          max: 3,
          filter: "TSI"
        }, {
          name: "Tercer y cuarto curso (Sistemas de Información)",
          roles: [ "Estudiante" ],
          max: 3,
          filter: "Sistemas de Información"
        }, {
          name: "Grado en CDIA",
          roles: [ "Estudiante" ],
          max: 3,
          filter: "CDIA"
        }, {
          name: "Másteres universitarios",
          roles: [ "Estudiante" ],
          max: 3,
          filter: "Master"
        } ],
        "Innovación Educativa": [ {
          name: "Innovación Educativa",
          roles: [ "Estudiante", "PDI" ],
          max: 1,
          filter: "Innovación"
        } ],
        "Reconocimiento PTGAS": [ {
          name: "PDI más valorado por PTGAS",
          roles: [ "PTGAS" ],
          max: 5,
          filter: "PDI"
        }, {
          name: "PTGAS en activo más valorado",
          roles: [ "PDI", "PTGAS" ],
          max: 5,
          filter: "PTGAS"
        } ],
      };
      // Element references

      const selectRol = document.getElementById("user-rol");

      const btnSaveRol = document.getElementById("btn-save-rol");

      const mainVotingArea = document.getElementById("main-voting-area");

      const setupProfileArea = document.getElementById("setup-profile");

      const selectMainCat = document.getElementById("main-cat-select");

      const selectCategoria = document.getElementById("categoria-select");

      const selectProfesor = document.getElementById("profesor-select");

      const subcatContainer = document.getElementById("subcat-container");

      const hiddenRol = document.getElementById("hidden-rol");

      const catHelp = document.getElementById("cat-help");

      const btnSubmitVote = document.getElementById("btn-submit-vote");

      const divEstudianteFields = document.getElementById("estudiante-fields");
      const selectCurso = document.getElementById("user-curso");
      const selectGrado = document.getElementById("user-grado");
      const divGradoContainer = document.getElementById("grado-container");
      
      const hiddenCurso = document.getElementById("hidden-curso");
      const hiddenGrado = document.getElementById("hidden-grado");

      const votesSummaryList = document.getElementById("votes-summary-list");
      const voteCountBadge = document.getElementById("vote-count-badge");
      
      const btnSubmitVotes = document.querySelectorAll(".btn-submit-vote");
      // Helper to populate main categories

      function populateMainCategories(rol, curso, grado) {
        if (!selectMainCat) return;
        selectMainCat.innerHTML = '<option value="" disabled selected>Elige un grupo de premios</option>';
        Object.keys(groupsData).forEach(groupName => {
          // Check if user role has at least ONE subcategory in this group
          const hasAccess = groupsData[groupName].some(cat => {
            const basicRoleAccess = cat.roles.includes(rol);
            if (rol !== 'Estudiante' || !basicRoleAccess) return basicRoleAccess;

            // If it's an academic category, check course-specific access
            const academicCats = [
              'Primer curso (Grados)', 'Segundo curso (Grados)', 
              'Tercer y cuarto curso (Software)', 'Tercer y cuarto curso (Computadores)', 
              'Tercer y cuarto curso (TSI)', 'Tercer y cuarto curso (Sistemas de Información)',
              'Grado en CDIA', 'Másteres universitarios'
            ];
            
            let courseAccess = true;
            if (academicCats.includes(cat.name)) {
              // Filtering logic for students
              if (curso === '1') courseAccess = (cat.name === 'Primer curso (Grados)');
              else if (curso === '2') courseAccess = (cat.name === 'Primer curso (Grados)' || cat.name === 'Segundo curso (Grados)');
              else if (curso === '3/4') {
                if (cat.name === 'Primer curso (Grados)' || cat.name === 'Segundo curso (Grados)') courseAccess = true;
                else {
                  const degreeCats = {
                    'Software': 'Tercer y cuarto curso (Software)',
                    'Computadores': 'Tercer y cuarto curso (Computadores)',
                    'TSI': 'Tercer y cuarto curso (TSI)',
                    'Sistemas': 'Tercer y cuarto curso (Sistemas de Información)'
                  };
                  courseAccess = (cat.name === degreeCats[grado]);
                }
              }
              else if (curso === 'CDIA') courseAccess = (cat.name === 'Grado en CDIA');
              else if (curso === 'Master') courseAccess = (cat.name === 'Másteres universitarios');
              else courseAccess = false;
            }

            if (!courseAccess) return false;

            // Also check if there are votes remaining in this group/category
            let aggregateUsed = votesByCategory[cat.name] || 0;
            
            // Exclusive rule for 3/4: if they voted in MD1, they can't vote in MD2 (and vice versa)
            if (rol === 'Estudiante' && curso === '3/4' && (cat.name === 'Primer curso (Grados)' || cat.name === 'Segundo curso (Grados)')) {
                const other = cat.name === 'Primer curso (Grados)' ? 'Segundo curso (Grados)' : 'Primer curso (Grados)';
                if (votesByCategory[other] && votesByCategory[other] > 0) return false;
            }

            return aggregateUsed < cat.max;
          });

          if (hasAccess) {
            const option = document.createElement("option");
            option.value = groupName;
            option.textContent = groupName;
            selectMainCat.appendChild(option);
          }
        });
      }
      // Populates subcategories when a main category is chosen

      function populateSubCategories(groupName, rol, curso, grado) {
        if (!selectCategoria) return;
        selectCategoria.innerHTML = '<option value="" disabled selected>Elige un curso o variante</option>';
        selectCategoria.disabled = false;
        subcatContainer.style.display = "block";
        const subcats = groupsData[groupName];
        // Calculate aggregate used votes if it's the "Mérito Docente" group
        let aggregateUsed = 0;
        if (groupName === "Mérito Docente") {
          subcats.forEach(cat => {
            aggregateUsed += votesByCategory[cat.name] || 0;
          });
        }
        subcats.forEach(cat => {
          let hasAccess = cat.roles.includes(rol);
          
          if (hasAccess && rol === 'Estudiante') {
            const academicCats = [
              'Primer curso (Grados)', 'Segundo curso (Grados)', 
              'Tercer y cuarto curso (Software)', 'Tercer y cuarto curso (Computadores)', 
              'Tercer y cuarto curso (TSI)', 'Tercer y cuarto curso (Sistemas de Información)',
              'Grado en CDIA', 'Másteres universitarios'
            ];
            
            if (academicCats.includes(cat.name)) {
              if (curso === '1') hasAccess = (cat.name === 'Primer curso (Grados)');
              else if (curso === '2') hasAccess = (cat.name === 'Primer curso (Grados)' || cat.name === 'Segundo curso (Grados)');
              else if (curso === '3/4') {
                if (cat.name === 'Primer curso (Grados)' || cat.name === 'Segundo curso (Grados)') {
                    // Exclusive rule for 3/4: if they voted in MD1, they can't vote in MD2 (and vice versa)
                    const other = cat.name === 'Primer curso (Grados)' ? 'Segundo curso (Grados)' : 'Primer curso (Grados)';
                    if (votesByCategory[other] && votesByCategory[other] > 0) {
                        hasAccess = false;
                    } else {
                        hasAccess = true;
                    }
                } else {
                  const degreeCats = {
                    'Software': 'Tercer y cuarto curso (Software)',
                    'Computadores': 'Tercer y cuarto curso (Computadores)',
                    'TSI': 'Tercer y cuarto curso (TSI)',
                    'Sistemas': 'Tercer y cuarto curso (Sistemas de Información)'
                  };
                  hasAccess = (cat.name === degreeCats[grado]);
                }
              }
              else if (curso === 'CDIA') hasAccess = (cat.name === 'Grado en CDIA');
              else if (curso === 'Master') hasAccess = (cat.name === 'Másteres universitarios');
              else hasAccess = false;
            }
          }

          if (hasAccess) {
            const option = document.createElement("option");
            option.value = cat.name;
            const used = votesByCategory[cat.name] || 0;
            const remaining = cat.max - used;
            if (remaining <= 0) {
              // Option is not even created (hidden)
              return;
            } else {
              option.textContent = `${cat.name} (${remaining} votos restantes en total)`;
            }
            option.dataset.max = cat.max;
            option.dataset.used = used;
            option.dataset.filter = cat.filter;
            selectCategoria.appendChild(option);
          }
        });
      }

      function updateVotesUI() {
          if (!votesSummaryList) return;
          votesSummaryList.innerHTML = "";
          userVotesList.forEach(v => {
              const li = document.createElement("li");
              li.className = "list-group-item px-0";
              li.innerHTML = `<strong>${v.categoria}:</strong><br />
                  <span class="text-muted"><i class="fa-solid fa-check text-success"></i> ${v.participante?.nombreCompleto || 'Candidato'}</span>`;
                  votesSummaryList.appendChild(li);
          });
          voteCountBadge.textContent = userVotesList.length;
      }

      document.querySelectorAll(".ajax-vote-form").forEach(form => {
          form.addEventListener("submit", async function(e) {
              e.preventDefault();
              
              const btn = this.querySelector(".btn-submit-vote");
              const originalBtnHtml = btn.innerHTML;
              btn.disabled = true;
              btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i>Registrando...';

              const formData = new FormData(this);
              // Ensure we pick up the latest role/course/grado from hidden fields or global constants
              const activeRol = userRol || (hiddenRol ? hiddenRol.value : '');
              const activeCurso = userCurso || (hiddenCurso ? hiddenCurso.value : '');
              const activeGrado = userGrado || (hiddenGrado ? hiddenGrado.value : '');
              
              if (activeRol) formData.set('rol', activeRol);
              if (activeCurso) formData.set('curso', activeCurso);
              if (activeGrado) formData.set('grado', activeGrado);
              formData.set('_format', 'json');

              const csrfToken = document.querySelector('input[name="_csrf"]')?.value;
              
              try {
                  const response = await fetch('/votacion', {
                      method: 'POST',
                      body: formData,
                      headers: {
                          'Accept': 'application/json',
                          'X-Requested-With': 'XMLHttpRequest',
                          'X-Is-Ajax': 'true',
                          'X-CSRF-TOKEN': csrfToken
                      }
                  });

                  // Detect silent redirections (e.g., session timeout redirecting to /login)
                  if (response.redirected && !response.url.includes('/votacion')) {
                      throw new Error("Sesión expirada o redirección inesperada a: " + response.url);
                  }

                  if (!response.ok) {
                      const contentType = response.headers.get("content-type");
                      if (contentType && contentType.includes("application/json")) {
                          const json = await response.json();
                          throw new Error(json.message || "Error en el servidor");
                      } else {
                          const text = await response.text();
                          console.error("Non-JSON error response", text);
                          throw new Error("El servidor devolvió una respuesta inesperada (HTML). Posible error de sesión o CSRF.");
                      }
                  }

                  const contentType = response.headers.get("content-type");
                  if (!contentType || !contentType.includes("application/json")) {
                      throw new Error("El servidor no devolvió JSON. Posible redirección inesperada.");
                  }

                  const result = await response.json();

                  if (result.success) {
                      userVotesList = result.userVotes;
                      // Re-calculate votesByCategory
                      votesByCategory = {};
                      userVotesList.forEach(v => {
                          votesByCategory[v.categoria] = (votesByCategory[v.categoria] || 0) + 1;
                      });

                      updateVotesUI();
                      
                      // Remove any existing alerts first
                      const existingAlerts = this.parentNode.querySelectorAll(".alert-success, .alert-danger");
                      existingAlerts.forEach(a => a.remove());

                      // Show success alert
                      const alertDiv = document.createElement("div");
                      alertDiv.className = "alert alert-success alert-dismissible fade show mt-3";
                      alertDiv.innerHTML = `${result.message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
                      this.parentNode.insertBefore(alertDiv, this);
                      
                      // Smooth scroll to alert
                      alertDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });

                      // Maintain category group and category if possible
                      const currentMain = selectMainCat.value;
                      const currentCat = selectCategoria.value;

                      populateMainCategories(activeRol, activeCurso, activeGrado);
                      if (currentMain) {
                        selectMainCat.value = currentMain;
                        populateSubCategories(currentMain, activeRol, activeCurso, activeGrado);
                        
                        // Check if the category is still available
                        let catExists = Array.from(selectCategoria.options).some(o => o.value === currentCat);
                        if (catExists) {
                            selectCategoria.value = currentCat;
                            // Trigger change to refresh teacher list
                            selectCategoria.dispatchEvent(new Event('change'));
                        } else {
                            selectProfesor.innerHTML = '<option value="" disabled selected>Primero elige una variante</option>';
                            selectProfesor.disabled = true;
                            catHelp.innerHTML = "";
                        }
                      }

                  } else {
                      // Show error alert instead of alert() box for better UX
                      const alertDiv = document.createElement("div");
                      alertDiv.className = "alert alert-danger alert-dismissible fade show mt-3";
                      alertDiv.innerHTML = `${result.message || "Error al registrar el voto"}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
                      this.parentNode.insertBefore(alertDiv, this);
                      alertDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
                  }
              } catch (error) {
                  console.error(error);
                  const alertDiv = document.createElement("div");
                  alertDiv.className = "alert alert-danger alert-dismissible fade show mt-3";
                  alertDiv.innerHTML = `<strong>Error:</strong> ${error.message || "Error de conexión al enviar el voto"}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
                  this.parentNode.insertBefore(alertDiv, this);
                  alertDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
              } finally {
                  btn.disabled = false;
                  btn.innerHTML = originalBtnHtml;
              }
          });
      });

      if (selectRol) {
        selectRol.addEventListener("change", function() {
          if (this.value === 'Estudiante') {
            divEstudianteFields.style.display = 'block';
          } else {
            divEstudianteFields.style.display = 'none';
          }
        });

        if (selectCurso) {
          selectCurso.addEventListener("change", function() {
            if (this.value === '3/4') {
              divGradoContainer.style.display = 'block';
            } else {
              divGradoContainer.style.display = 'none';
              selectGrado.value = "";
            }
          });
        }

        btnSaveRol.addEventListener("click", function() {
          if (!selectRol.value) {
            alert("Por favor selecciona un perfil");
            return;
          }
          
          if (selectRol.value === 'Estudiante') {
            if (!selectCurso.value) {
              alert("Por favor selecciona tu curso");
              return;
            }
            if (selectCurso.value === '3/4' && !selectGrado.value) {
              alert("Por favor selecciona tu grado");
              return;
            }
          }

          // Show form conditionally
          setupProfileArea.style.display = "none";
          mainVotingArea.style.display = "block";
          const chosenRol = selectRol.value;
          const chosenCurso = selectCurso.value;
          const chosenGrado = selectGrado.value;
          
          hiddenRol.value = chosenRol;
          hiddenCurso.value = chosenCurso;
          hiddenGrado.value = chosenGrado;
          
          populateMainCategories(chosenRol, chosenCurso, chosenGrado);
        });
      }
      // If rol is already set

      if (userRol) {
        populateMainCategories(userRol, userCurso, userGrado);
      }
      // Main category change event

      if (selectMainCat) {
        selectMainCat.addEventListener("change", function() {
          const groupName = this.options[this.selectedIndex].value;
          const activeRol = userRol || (hiddenRol ? hiddenRol.value : '');
          const activeCurso = userCurso || (hiddenCurso ? hiddenCurso.value : '');
          const activeGrado = userGrado || (hiddenGrado ? hiddenGrado.value : '');

          // Reset child dropdowns
          selectProfesor.innerHTML = '<option value="" disabled selected>Primero elige una variante</option>';
          selectProfesor.disabled = true;
          if (catHelp) catHelp.innerHTML = "";
          populateSubCategories(groupName, activeRol, activeCurso, activeGrado);
        });
      }
      // Behavior when category is selected

      if (selectCategoria) {
        selectCategoria.addEventListener("change", function() {
          const opt = this.options[this.selectedIndex];
          const catName = opt.value;
          const filterTag = opt.dataset.filter;
          catHelp.innerHTML = `Límites aplicados. Has usado <strong>${opt.dataset.used}</strong> de <strong>${opt.dataset.max}</strong> votos permitidos.`;
          // Populate Profesores based on category
          selectProfesor.innerHTML = '<option value="" disabled selected>Elige a un candidato</option>';
          selectProfesor.disabled = false;
          allProfesores.filter(p => p.categoria === catName).sort((a, b) => (a.nombreCompleto ?? a.nombre_completo ?? "").localeCompare(b.nombreCompleto ?? b.nombre_completo ?? "")).forEach(p => {
            const option = document.createElement("option");
            option.value = p.id;
            option.textContent = p.nombreCompleto ?? p.nombre_completo;
            selectProfesor.appendChild(option);
          });
        });
      }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js">

    </script>
  </body>
</html>
