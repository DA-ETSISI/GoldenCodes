<!DOCTYPE html>
<html lang="es">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      Panel de Administración - Códigos de Oro
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Roboto:wght@300;400;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/app.css" />

    <style>
      body {
        padding-top: 36px;
        background-color: #f8f9fa;
      }
      
      .admin-header {
        background: #1a1a1a;
        color: #ffd700;
        border-bottom: 3px solid #ffd700;
      }
    </style>
  </head>

  <body>
    <!-- NAVEGACIÓN ADMIN -->
    <nav class="navbar navbar-expand-lg fixed-top py-3 admin-header shadow">
      <div class="container-fluid px-4">
        <a class="navbar-brand fs-4 text-warning" href="#">
          <i class="fa-solid fa-user-shield me-2"></i>Códigos de Oro <span>Admin</span>
        </a>
        <div class="ms-auto d-flex align-items-center gap-3">
          <a href="/" class="btn btn-outline-warning btn-sm">
            <i class="fa-solid fa-arrow-left me-2"></i>Volver a la Web
                </a>
          <form action="/admin/logout" method="POST" class="m-0">
            {{ csrfField() }}
                    <button type="submit" class="btn btn-danger btn-sm fw-bold">
              <i class="fa-solid fa-right-from-bracket me-2"></i>Cerrar Sesión Segura
                    </button>
          </form>
        </div>
      </div>
    </nav>

    <section class="py-5 mt-5">
      <div class="container-fluid px-4">
        @if(flashMessages.has('success'))
          <div class="alert alert-success alert-dismissible fade show mb-4">
            {{ flashMessages.get('success') }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        @endif
        @if(flashMessages.has('error'))
          <div class="alert alert-danger alert-dismissible fade show mb-4">
            {{ flashMessages.get('error') }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        @endif

        <div class="d-flex justify-content-between align-items-center mb-4">
          <h2 class="display-5 fw-bold text-dark">
            <i class="fa-solid fa-chart-bar text-warning me-2"></i>Resultados en Tiempo Real
          </h2>
          <div class="d-flex gap-2">
            <form action="/admin" method="GET" class="d-flex gap-2">
              <input
                type="email"
                name="email"
                class="form-control"
                placeholder="Buscar por correo..."
                value="{{ searchEmail || '' }}"
                required
              />
              <button type="submit" class="btn btn-warning fw-bold">
                <i class="fa-solid fa-magnifying-glass me-2"></i>Buscar Votos
              </button>
            </form>
            @if(searchedUser || searchEmail)
              <a href="/admin" class="btn btn-outline-secondary">
                <i class="fa-solid fa-xmark me-2"></i>Limpiar
              </a>
            @endif
            <button class="btn btn-dark" onclick="window.location.reload();">
              <i class="fa-solid fa-rotate-right me-2"></i>Actualizar Datos
            </button>
          </div>
        </div>

        <div class="row mb-5">
          <div class="col-md-4 mb-3 mb-md-0">
            <div class="card shadow-sm border-0 border-start border-primary border-4 h-100">
              <div class="card-body">
                <h6 class="text-muted fw-bold mb-1">Personas que han votado</h6>
                <h3 class="mb-0 text-white">{{ totalVoters }}</h3>
              </div>
            </div>
          </div>
          <div class="col-md-4 mb-3 mb-md-0">
            <div class="card shadow-sm border-0 border-start border-success border-4 h-100">
              <div class="card-body">
                <h6 class="text-muted fw-bold mb-1">Votantes @upm.es</h6>
                <h3 class="mb-0 text-white">{{ upmVoters }}</h3>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card shadow-sm border-0 border-start border-info border-4 h-100">
              <div class="card-body">
                <h6 class="text-muted fw-bold mb-1">Votantes @alumnos.upm.es</h6>
                <h3 class="mb-0 text-white">{{ alumnosVoters }}</h3>
              </div>
            </div>
          </div>
        </div>

        @if(searchEmail)
          <div class="row mb-5">
            <div class="col-12">
              <div class="card shadow-sm border-0 border-start border-warning border-5">
                <div class="card-header bg-dark text-white py-3">
                  <h5 class="mb-0">
                    <i class="fa-solid fa-search me-2"></i>Resultado de Búsqueda para: {{ searchEmail }}
                  </h5>
                </div>
                <div class="card-body">
                  @if(searchedUser)
                    <div class="row">
                      <div class="col-md-4 mb-3 mb-md-0">
                        <div class="p-3 bg-light rounded shadow-sm h-100">
                          <h6 class="text-uppercase text-muted small fw-bold mb-3">
                            Información del Usuario
                          </h6>
                          <p class="mb-1"><strong>Nombre:</strong> {{ searchedUser.nombre || 'N/A' }}</p>
                          <p class="mb-1"><strong>Email:</strong> {{ searchedUser.email }}</p>
                          <p class="mb-1"><strong>Rol:</strong> <span class="badge bg-warning text-dark">{{ searchedUser.rol || 'Sin asignar' }}</span></p>
                          <p class="mb-3"><strong>Votos realizados:</strong> <span class="badge bg-dark">{{ userVotes.length }}</span></p>
                          <hr />
                          <form action="/admin/users/{{ searchedUser.id }}/reset" method="POST" onsubmit="return confirm('¿Estás SEGURO de que quieres eliminar todos los votos de este usuario y resetear su perfil? Esta acción descontará sus votos de los candidatos y no se puede deshacer.');">
                            {{ csrfField() }}
                            <button type="submit" class="btn btn-outline-danger w-100 btn-sm">
                              <i class="fa-solid fa-trash-can me-2"></i>Eliminar Votos y Resetear
                            </button>
                          </form>
                        </div>
                      </div>
                      <div class="col-md-8">
                        @if(userVotes.length > 0)
                          <div class="table-responsive">
                            <table class="table table-sm table-hover border">
                              <thead class="table-light">
                                <tr>
                                  <th>Categoría</th>
                                  <th>Candidato Votado</th>
                                  <th>Fecha</th>
                                </tr>
                              </thead>
                              <tbody>
                                @each(v in userVotes)
                                  <tr>
                                    <td class="small">{{ v.categoria }}</td>
                                    <td class="fw-bold">{{ v.participante.nombreCompleto }}</td>
                                    <td class="small text-muted">{{ v.createdAt.toFormat('dd/MM HH:mm') }}</td>
                                  </tr>
                                @endeach
                              </tbody>
                            </table>
                          </div>
                        @else
                          <div class="alert alert-info mb-0">
                            <i class="fa-solid fa-circle-info me-2"></i>Este usuario no ha registrado ningún voto todavía.
                          </div>
                        @endif
                      </div>
                    </div>
                  @else
                    <div class="alert alert-danger mb-0">
                      <i class="fa-solid fa-triangle-exclamation me-2"></i>No se ha encontrado ninguna cuenta registrada con el correo <strong>{{ searchEmail }}</strong>.
                    </div>
                  @endif
                </div>
              </div>
            </div>
          </div>
        @endif

        <div class="row">
          @each((participantes, categoria) in groupedResults)
            <div class="col-lg-6 mb-4">
              <div class="card shadow-sm h-100 border-0 border-top border-warning border-4">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                  <h5 class="mb-0 fw-bold text-dark">
                    {{ categoria }}
                  </h5>
                  @if(participantes.length > 5)
                    <button
                      class="btn btn-outline-dark btn-sm toggle-btn"
                      data-categoria="{{ categoria.replace(/[^a-zA-Z0-9]/g, '-') }}"
                    >
                      <i class="fa-solid fa-plus me-1"></i>Ver más
                                    </button>
                  @endif
                </div>
                <div class="card-body p-0">
                  <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0 align-middle">
                      <thead class="table-light">
                        <tr>
                          <th scope="col" class="ps-4" style="width: 10%;">
                            Pos
                          </th>
                          <th scope="col">
                            Participante
                          </th>
                          <th scope="col" class="text-center" style="width: 20%;">
                            Votos Recibidos
                          </th>
                        </tr>
                      </thead>
                      <tbody>
                        @each((p, index) in participantes)
                          <tr
                            class="{{ index === 0 && p.numero_votos > 0 ? 'table-warning fw-bold' : '' }} {{ index >= 5 ? 'd-none extra-row-' + categoria.replace(/[^a-zA-Z0-9]/g, '-') : '' }}"
                          >
                            <td class="ps-4">
                              @if(index === 0 && p.numero_votos > 0)
                                <i class="fa-solid fa-trophy text-warning"></i>
                              @else
                                #{{ index + 1 }}
                              @endif
                            </td>
                            <td>
                              {{ p.nombreCompleto }}
                            </td>
                            <td class="text-center">
                              <span class="badge {{ p.numero_votos > 0 ? 'bg-dark' : 'bg-secondary' }} fs-6 rounded-pill px-3">
                                {{ p.numero_votos }}
                                                        </span>
                            </td>
                          </tr>
                        @endeach
                                            
                        @if(participantes.length === 0)
                          <tr>
                            <td colspan="3" class="text-center text-muted py-4">
                              No hay candidatos registrados en esta categoría.
                            </td>
                          </tr>
                        @endif
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
          @endeach
        </div>
      </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js">

    </script>
    <script>
      document.querySelectorAll(".toggle-btn").forEach(btn => {
        btn.addEventListener("click", function() {
          const categoriaId = this.getAttribute("data-categoria");
          const extraRows = document.querySelectorAll(".extra-row-" + categoriaId);
          const isHidden = extraRows[0].classList.contains("d-none");
          if (isHidden) {
            extraRows.forEach(row => row.classList.remove("d-none"));
            this.innerHTML = '<i class="fa-solid fa-minus me-1"></i> Ver menos';
          } else {
            extraRows.forEach(row => row.classList.add("d-none"));
            this.innerHTML = '<i class="fa-solid fa-plus me-1"></i> Ver más';
          }
        });
      });
    </script>
  </body>
</html>
