<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Establecer Nueva Contraseña - Códigos de Oro</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Roboto:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        :root {
            --color-negro: #000000;
            --color-oro: #FFD700;
            --color-naranja: #FFA500;
            --color-gris-oscuro: #111111;
            --color-gris-fondo: #1a1a1a;
            --color-texto-claro: #f8e473;
        }

        body {
            background-color: var(--color-negro);
            color: var(--color-oro);
            font-family: 'Roboto', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            margin: 0;
            padding: 20px;
            background: linear-gradient(to bottom, var(--color-gris-oscuro) 0%, var(--color-negro) 100%);
        }

        .card {
            background-color: var(--color-negro);
            border: 1px solid var(--color-oro);
            border-radius: 10px;
            padding: 40px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 15px 40px rgba(255, 215, 0, 0.15);
            text-align: center;
        }

        h1 {
            font-family: 'Playfair Display', serif;
            margin-bottom: 20px;
            font-size: 1.5rem;
        }

        .form-group {
            text-align: left;
            margin-bottom: 20px;
        }

        label {
            display: block;
            font-size: 0.8rem;
            margin-bottom: 8px;
            text-transform: uppercase;
            font-weight: 600;
        }

        input {
            width: 100%;
            padding: 12px;
            background-color: var(--color-gris-fondo);
            border: 1.5px solid rgba(255, 215, 0, 0.25);
            border-radius: 6px;
            color: var(--color-oro);
            outline: none;
            box-sizing: border-box;
        }

        input:focus {
            border-color: var(--color-oro);
        }

        button {
            width: 100%;
            padding: 12px;
            background-color: var(--color-oro);
            color: var(--color-negro);
            border: none;
            border-radius: 6px;
            font-weight: 700;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 10px;
        }

        button:hover {
            background-color: var(--color-naranja);
        }

        .alert {
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 20px;
            font-size: 0.85rem;
        }

        .alert-error {
            background: rgba(200, 16, 46, 0.12);
            border: 1px solid #c8102e;
            color: #ff6b6b;
        }
    </style>
</head>
<body>
    <div class="card">
        <h1>Nueva Contraseña</h1>

        @if(flashMessages.has('error'))
            <div class="alert alert-error">
                {{ flashMessages.get('error') }}
            </div>
        @endif

        <form action="/reset-password" method="POST">
            {{ csrfField() }}
            <input type="hidden" name="token" value="{{ token }}">
            <input type="hidden" name="email" value="{{ email }}">
            
            <div class="form-group">
                <label for="password">Nueva Contraseña</label>
                <input type="password" id="password" name="password" required minlength="6">
            </div>

            <div class="form-group">
                <label for="confirmPassword">Confirmar Contraseña</label>
                <input type="password" id="confirmPassword" name="confirmPassword" required minlength="6">
            </div>

            <button type="submit">Restablecer Contraseña</button>
        </form>
    </div>

    <script>
        const form = document.querySelector('form');
        const pass = document.getElementById('password');
        const confirm = document.getElementById('confirmPassword');

        form.addEventListener('submit', (e) => {
            if (pass.value !== confirm.value) {
                e.preventDefault();
                alert('Las contraseñas no coinciden.');
            }
        });
    </script>
</body>
</html>
